{
  "name": "@fireimg/react",
  "version": "0.1.0",
  "description": "React components for optimized fireimg images",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react --external @fireimg/js",
    "prepublishOnly": "npm run build",
    "dev": "tsup src/index.ts --format esm,cjs --dts --external react --external @fireimg/js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fireimg/js": "*"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.2.66",
    "jsdom": "^26.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "fireimg",
    "react",
    "image",
    "optimization",
    "cdn"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FirelitStudio/fireimg-packages.git"
  }
}
